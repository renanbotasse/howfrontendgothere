---
import '../styles/global.css';
import { encyclopediaBlocks, seriesArticles } from '../data/navigation.js';

export interface Props {
  title: string;
  description?: string;
  currentPath?: string;
}

const { title, description = 'The history and fundamentals of frontend', currentPath = '' } = Astro.props;
const pathname = currentPath || Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — How Frontend Got Here</title>
  <meta name="description" content={description} />
  <link rel="icon" type="image/png" href="/favicon.png" />
</head>
<body>
  <div class="site-wrapper">

    <!-- Header -->
    <header class="site-header">
      <a href="/" class="site-logo">How Frontend Got <span>Here</span></a>

      <div class="site-search">
        <button class="site-search-btn" type="button">
          <svg class="site-search-icon" width="13" height="13" viewBox="0 0 13 13" fill="none">
            <circle cx="5.5" cy="5.5" r="4.5" stroke="currentColor" stroke-width="1.2"/>
            <line x1="9" y1="9" x2="12" y2="12" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
          </svg>
          <span class="site-search-placeholder">Search articles…</span>
          <kbd class="site-search-kbd">⌘K</kbd>
        </button>
      </div>

      <nav class="site-nav">
        <a href="/encyclopedia" class={pathname.startsWith('/encyclopedia') ? 'active' : ''}>Encyclopedia</a>
        <a href="/series" class={pathname.startsWith('/series') ? 'active' : ''}>Series</a>

        <div class="site-nav-divider"></div>

        <a href="https://hackernoon.com/u/renanb" target="_blank" rel="noopener" class="site-nav-icon" title="HackerNoon">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M2.25 0A2.25 2.25 0 0 0 0 2.25v19.5A2.25 2.25 0 0 0 2.25 24h19.5A2.25 2.25 0 0 0 24 21.75V2.25A2.25 2.25 0 0 0 21.75 0H2.25zm4.5 5.25h2.4l4.65 8.1V5.25H16.5v13.5h-2.4l-4.65-8.1v8.1H6.75V5.25z"/>
          </svg>
        </a>

        <a href="https://github.com/renanbotasse" target="_blank" rel="noopener" class="site-nav-icon" title="GitHub">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
          </svg>
        </a>

        <a href="https://www.linkedin.com/in/renanbotasse/" target="_blank" rel="noopener" class="site-nav-icon" title="LinkedIn">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>

        <a href="https://renanbotasse.vercel.app/" target="_blank" rel="noopener" class="site-nav-icon" title="Portfolio">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M20 7H4a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"/><path d="M16 3H8a2 2 0 0 0-2 2v2h12V5a2 2 0 0 0-2-2z"/>
          </svg>
        </a>
      </nav>

      <button class="hamburger" id="hamburger-btn" type="button" aria-label="Open navigation">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </header>

    <!-- Sidebar -->
    <aside class="sidebar">

      {pathname.startsWith('/series') && (
        <div class="sidebar-section">
          <div class="sidebar-label">The Web Stack Beneath<br />Your Framework</div>
          <ul class="sidebar-links">
            {seriesArticles.map(article => (
              <li>
                <a
                  href={`/series/${article.slug}`}
                  class={pathname === `/series/${article.slug}` ? 'active' : ''}
                >
                  {article.title}
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}

      {(pathname.startsWith('/encyclopedia') || pathname === '/') && (
        encyclopediaBlocks.map(block => (
          <div class="sidebar-section">
            <div class="sidebar-label">{block.label}</div>
            <ul class="sidebar-links">
              {block.articles.map(article => (
                <li>
                  <a
                    href={`/encyclopedia/${article.slug}`}
                    class={pathname === `/encyclopedia/${article.slug}` ? 'active' : ''}
                  >
                    {article.title}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      )}

    </aside>

    <!-- Main -->
    <main class="main-content">
      <div class="content-inner">
        <slot />
      </div>
    </main>

  </div>

  <div class="sidebar-overlay" id="sidebar-overlay"></div>

  <!-- Image zoom modal (mobile) -->
  <div class="img-modal" id="img-modal" role="dialog" aria-modal="true">
    <button class="img-modal-close" id="img-modal-close" aria-label="Close">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="1" y1="1" x2="13" y2="13"/>
        <line x1="13" y1="1" x2="1" y2="13"/>
      </svg>
    </button>
    <div class="img-modal-scroll">
      <img class="img-modal-img" id="img-modal-img" src="" alt="" />
    </div>
  </div>

  <script>
    const btn = document.getElementById('hamburger-btn');
    const sidebar = document.querySelector('.sidebar');
    const overlay = document.getElementById('sidebar-overlay');

    btn.addEventListener('click', () => {
      const open = sidebar.classList.toggle('open');
      overlay.classList.toggle('active', open);
      btn.classList.toggle('open', open);
      document.body.style.overflow = open ? 'hidden' : '';
    });

    overlay.addEventListener('click', () => {
      sidebar.classList.remove('open');
      overlay.classList.remove('active');
      btn.classList.remove('open');
      document.body.style.overflow = '';
    });

    // Image zoom modal (mobile only)
    const imgModal = document.getElementById('img-modal');
    const imgModalImg = document.getElementById('img-modal-img');
    const imgModalClose = document.getElementById('img-modal-close');

    function openImgModal(src, alt) {
      imgModalImg.src = src;
      imgModalImg.alt = alt;
      imgModal.classList.add('active');
      document.body.style.overflow = 'hidden';
    }

    function closeImgModal() {
      imgModal.classList.remove('active');
      imgModalImg.src = '';
      document.body.style.overflow = '';
    }

    document.querySelectorAll('.prose img').forEach(img => {
      img.addEventListener('click', () => {
        if (window.innerWidth > 900) return;
        openImgModal(img.src, img.alt);
      });
    });

    imgModalClose.addEventListener('click', closeImgModal);

    imgModal.addEventListener('click', e => {
      if (e.target === imgModal || e.target === imgModal.querySelector('.img-modal-scroll')) {
        closeImgModal();
      }
    });

    document.addEventListener('keydown', e => {
      if (e.key === 'Escape') closeImgModal();
    });
  </script>
</body>
</html>
